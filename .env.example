# Environment Configuration Examples
# Copy this file to .env and update with your actual configuration

# ============================================================================
# WORKFLOW STORAGE CONFIGURATION (for workflows and processing artifacts)
# ============================================================================

# Google Cloud Storage bucket for workflows (optional)
# If not set, workflows will be stored locally in .workflow_data/
# WORKFLOW_BUCKET=your-workflow-bucket

# Prefix for all workflow objects in the bucket
# WORKFLOW_PREFIX=workflows

# Local root directory for workflow storage (when not using GCS)
# Default: .workflow_data
# WORKFLOW_LOCAL_ROOT=.workflow_data

# Allow local fallback if GCS fails or credentials are missing
# Set to 'false' to require GCS and fail if unavailable
# Default: true
# WORKFLOW_LOCAL_FALLBACK=true

# ============================================================================
# FILE STORAGE CONFIGURATION (for uploads and created files)
# ============================================================================

# Google Cloud Storage bucket for file storage (optional)
# If not set, files will be stored locally in .file_data/
# FILE_BUCKET=your-files-bucket

# Prefix for all file objects in the bucket
# FILE_PREFIX=files

# Local root directory for file storage (when not using GCS)
# Default: .file_data
# FILE_LOCAL_ROOT=.file_data

# Allow local fallback if GCS fails or credentials are missing
# Set to 'false' to require GCS and fail if unavailable
# Default: true
# FILE_LOCAL_FALLBACK=true

# ============================================================================
# GOOGLE CLOUD AUTHENTICATION
# ============================================================================

# Path to Google Cloud service account JSON key file
# Required if using Google Cloud Storage
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================================
# OTHER CONFIGURATION
# ============================================================================

# API Keys for various services
# GOOGLE_API_KEY=your-google-api-key

# Flask environment
FLASK_ENV=development

# Server port
PORT=8080
